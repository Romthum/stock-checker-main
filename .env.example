POSTGRES_PASSWORD=change-me-local-db-password
AUTH_SECRET=change-me-to-at-least-32-characters-long
GRAFANA_PASSWORD=change-me-grafana-password
CLOUDFLARE_TUNNEL_TOKEN=

DATABASE_URL=postgresql://pos_app:change-me-local-db-password@localhost:5432/pos
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=ChangeMe-Owner-Password-123!
ADMIN_DISPLAY_NAME=Store Owner
ALLOW_DEV_AUTH_FALLBACK=true
ALLOW_DEV_FILE_STORE=true

# Local storage paths on the machine that runs Docker.
# Use relative paths for simple installs, or absolute paths such as D:/pos-data/postgres.
POSTGRES_DATA_DIR=./data/postgres
UPLOADS_DIR=./data/uploads
REDIS_DATA_DIR=./data/redis
GRAFANA_DATA_DIR=./data/grafana
PROMETHEUS_DATA_DIR=./data/prometheus
NGINX_LOG_DIR=./data/nginx/logs

# Choose where daily database backups are written.
# Example for an external drive on Windows: E:/pos-backups/postgres
BACKUP_DIR=./backups/postgres
